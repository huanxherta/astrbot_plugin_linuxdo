{
  "top_limit": {
    "description": "每日热帖展示数量",
    "type": "int",
    "hint": "1-100，建议 30",
    "default": 30
  },
  "new_limit": {
    "description": "最近活跃展示数量",
    "type": "int",
    "hint": "1-150，建议 60",
    "default": 60
  },
  "fresh_limit": {
    "description": "最新发布展示数量",
    "type": "int",
    "hint": "1-150，建议 60",
    "default": 60
